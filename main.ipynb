   ],
   "source": [
    "from langchain_ollama import OllamaLLM\n",
    "\n",
    "llm = OllamaLLM(model=\"gpt-oss-safeguard:20b\")\n",
    "response = llm.invoke(\"من انت؟\")\n",
    "print(response)"
   ]
